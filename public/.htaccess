# =========================================
# 301 redirects for broken/old URLs
# =========================================
Redirect 301 /blog/contact-us/ /contact/
Redirect 301 /blog/contact-us /contact/
Redirect 301 /blog/edmonton /blog/
Redirect 301 /blog/our-collections/bracelet/ /blog/
Redirect 301 /blog/our-collections/rings/ /blog/
Redirect 301 /blog/surrey /blog/
Redirect 301 /blog/surrey/ /blog/

Redirect 301 /contact-us /contact/
Redirect 301 /contact-us/ /contact/
Redirect 301 /contact.html /contact/
Redirect 301 /pages/about-us /about/
Redirect 301 /pages/about-us/ /about/
Redirect 301 /bharat-jewellers-edmonton /edmonton/
Redirect 301 /bharat-jewellers-edmonton/ /edmonton/
Redirect 301 /bharat-jewellers-blogs/diamond-jewelry-near-me /blog/diamond-jewelry-near-me/
Redirect 301 /bharat-jewellers-blogs/diamond-jewelry-near-me/ /blog/diamond-jewelry-near-me/
Redirect 301 /collections/diamond /diamond-jewellery/
Redirect 301 /collections/diamond/ /diamond-jewellery/
Redirect 301 /collections/bridal /bridal-sets/
Redirect 301 /collections/bridal/ /bridal-sets/
Redirect 301 /our-collections/necklace /gold-jewellery/
Redirect 301 /our-collections/necklace/ /gold-jewellery/
Redirect 301 /our-collections/rings /diamond-jewellery/
Redirect 301 /our-collections/rings/ /diamond-jewellery/
