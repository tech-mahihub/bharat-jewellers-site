# 301 redirects for broken/old URLs (do not modify /cdn-cgi/l/email-protection)
# Invalid blog paths → main blog page
Redirect 301 /blog/contact-us/ /blog/
Redirect 301 /blog/edmonton /blog/
Redirect 301 /blog/our-collections/bracelet/ /blog/
Redirect 301 /blog/our-collections/rings/ /blog/
Redirect 301 /blog/surrey /blog/
Redirect 301 /blog/surrey/ /blog/

# Clean URLs – hide .html extensions
<IfModule mod_rewrite.c>
RewriteEngine On

# Skip assets and special paths
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/blog/
RewriteCond %{REQUEST_URI} !^/cdn-cgi/

# A) Redirect .html URLs to clean URLs (e.g., /contact.html -> /contact)
RewriteCond %{REQUEST_URI} !^/404\.html$
RewriteCond %{REQUEST_FILENAME} -f
RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

# B) Internally rewrite clean URLs to .html (e.g., /contact -> contact.html)
RewriteCond %{REQUEST_URI} !^/assets/
RewriteCond %{REQUEST_URI} !^/blog/
RewriteCond %{REQUEST_URI} !^/cdn-cgi/
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]
</IfModule>

# Custom 404 page for Bharat Jewellers
ErrorDocument 404 /404.html
