---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Live Gold Rates - Bharat Jewellers";
const pageDescription = "Live gold rates and pricing insights from Bharat Jewellers.";
const canonicalURL = "https://bharatjewellers.ca/live-gold-rates/";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const ogTitle = "Live Gold Rates - Bharat Jewellers";
const keywords = "live gold rates, gold price today, Bharat Jewellers, Surrey Calgary Edmonton gold rates";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
>
  <Fragment slot="head">
    <!-- Google tag (gtag.js) -->
  </Fragment>
  <section class="section gold-hero">
              <div class="content-wrap gold-hero-inner">
                  <h1>Live Gold Rates – Surrey, Calgary &amp; Edmonton</h1>
                  <p>Real-time gold prices to help you make informed jewellery and investment decisions</p>
                  <div class="hero-divider"></div>
              </div>
          </section>
  
          <section class="section gold-live">
              <div class="content-wrap">
                  <div class="gold-live-card">
                      <div class="gold-live-header">
                          <div class="gold-live-select">
                              <span class="gold-live-label">Location</span>
                              <span class="gold-live-value">Calgary</span>
                          </div>
                          <div class="gold-live-meta">
                              <span>Currency: CAD</span>
                              <span>Prices update automatically</span>
                          </div>
                      </div>
                      <div class="gold-live-chart">
                          <iframe
                              src="https://goldbroker.com/widget/live/XAU?currency=CAD&height=320"
                              title="Live Gold Price (CAD)"
                              loading="lazy"
                              referrerpolicy="no-referrer"
                              scrolling="no">
                          </iframe>
                      </div>
                      <div class="gold-live-caption">
                          LIVE GOLD PRICE · SOURCE: GOLDBROKER
                      </div>
                  </div>
              </div>
          </section>
  
          <section class="section gold-explain">
              <div class="content-wrap gold-explain-grid">
                  <div class="gold-explain-text">
                      <h2>Why Gold Prices Change Daily</h2>
                      <p>Gold rates shift with global market activity and economic trends. Staying informed helps you plan jewellery purchases and long-term investments with confidence.</p>
                      <ul>
                          <li>Market demand and global supply levels</li>
                          <li>USD/CAD exchange rate movements</li>
                          <li>International economic trends</li>
                          <li>Inflation and interest rate changes</li>
                      </ul>
                  </div>
                  <div class="gold-explain-image">
                      <img src="/assets/images/Gold-rate-live-calgary.webp" alt="Gold rate live Calgary">
                  </div>
              </div>
          </section>
  
          <section class="section gold-local">
              <div class="content-wrap gold-local-inner">
                  <h2>Gold Prices in Calgary</h2>
                  <p>Our Calgary clients rely on daily gold rates to plan jewellery purchases with clarity. Track live pricing to understand timing, purity, and value before you buy.</p>
              </div>
          </section>
  
          <section class="section gold-tips">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Quick Buyer Tips</h2>
                  </div>
                  <div class="gold-tips-grid">
                      <div class="gold-tip-card">
                          <div class="gold-tip-icon">✓</div>
                          <h3>Hallmark Purity</h3>
                          <p>Always verify hallmark certification for purity and authenticity.</p>
                      </div>
                      <div class="gold-tip-card">
                          <div class="gold-tip-icon">✓</div>
                          <h3>Making Charges</h3>
                          <p>Understand craftsmanship fees before finalizing your purchase.</p>
                      </div>
                      <div class="gold-tip-card">
                          <div class="gold-tip-icon">✓</div>
                          <h3>Compare Rates</h3>
                          <p>Check daily rates so you know when pricing is most favorable.</p>
                      </div>
                      <div class="gold-tip-card">
                          <div class="gold-tip-icon">✓</div>
                          <h3>Jewellery vs Investment</h3>
                          <p>Decide between investment bars or finished jewellery pieces.</p>
                      </div>
                  </div>
              </div>
          </section>
  
          <section class="section gold-faq">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Gold Rate FAQs</h2>
                  </div>
                  <div class="faq-list">
                      <details>
                          <summary>How often are live gold rates updated?</summary>
                          <p>Rates are designed to refresh automatically based on real-time market feeds.</p>
                      </details>
                      <details>
                          <summary>Are rates the same across all Bharat Jewellers locations?</summary>
                          <p>Rates follow global pricing with local adjustments based on currency and market conditions.</p>
                      </details>
                      <details>
                          <summary>Do making charges change with gold price?</summary>
                          <p>Making charges are separate and vary by design complexity and craftsmanship.</p>
                      </details>
                  </div>
              </div>
          </section>
  
          <section class="section gold-cta">
              <div class="content-wrap">
                  <div class="about-cta-card">
                      <h2>Visit Bharat Jewellers Today</h2>
                      <p>Get transparent pricing and expert guidance at our stores</p>
                      <a class="btn-primary" href="/contact/">Contact Us</a>
                  </div>
              </div>
          </section>
</BaseLayout>
