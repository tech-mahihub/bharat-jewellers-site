---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Privacy Policy - Bharat Jewellers";
const pageDescription = "Privacy Policy for Bharat Jewellers website and services.";
const canonicalURL = "https://bharatjewellers.ca/privacy-policy/";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const ogTitle = "Privacy Policy - Bharat Jewellers";
const keywords = "Bharat Jewellers, privacy policy, data protection";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
const bodyClass = "legal-page";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
  bodyClass={bodyClass}
>
  <Fragment slot="head">
    <!-- Fonts -->
        <!-- Google tag (gtag.js) -->
  </Fragment>
  <section class="section collections-hero">
              <div class="content-wrap collections-hero-inner">
                  <h1>Privacy Policy</h1>
                  <p>Last updated: <span class="js-last-updated"></span></p>
                  <div class="hero-divider"></div>
              </div>
          </section>
  
          <section class="section">
              <div class="content-wrap">
                  <p>
                      At Bharat Jewellers, accessible from bharatjewellers.ca, protecting your privacy is a priority.
                      This Privacy Policy explains the types of information we collect and how we use it.
                      If you have any questions or require more details about our practices, feel free to contact us.
                  </p>
                  <p>
                      This Privacy Policy applies only to information collected through our website and not to offline
                      activities or channels.
                  </p>
  
                  <div class="about-divider"></div>
  
                  <h3>Consent</h3>
                  <p>By using our website, you consent to the terms of this Privacy Policy.</p>
  
                  <div class="about-divider"></div>
  
                  <h3>Information We Collect</h3>
                  <p>We may request personal information such as:</p>
                  <ul>
                      <li>Name, email address, and phone number when you contact us.</li>
                      <li>Address, payment details, and preferences when you place an order.</li>
                  </ul>
                  <p>Additional information may include:</p>
                  <ul>
                      <li>Log data, including IP address, browser type, and visit timestamps.</li>
                      <li>Cookies to improve website performance and user experience.</li>
                  </ul>
  
                  <div class="about-divider"></div>
  
                  <h3>How We Use Your Information</h3>
                  <p>We use the collected information to:</p>
                  <ul>
                      <li>Provide, operate, and improve our website and services.</li>
                      <li>Process orders and transactions.</li>
                      <li>Respond to inquiries and offer support.</li>
                      <li>Send promotional offers and updates, with your consent.</li>
                      <li>Prevent fraudulent or unauthorized activities.</li>
                  </ul>
  
                  <div class="about-divider"></div>
  
                  <h3>Cookies and Tracking Technologies</h3>
                  <p>
                      Our website uses cookies to analyze traffic and personalize your experience.
                      You can adjust cookie settings in your browser preferences.
                  </p>
  
                  <div class="about-divider"></div>
  
                  <h3>Third-Party Services</h3>
                  <p>
                      We may share information with trusted third parties, such as payment processors, to fulfill your
                      requests. These partners are obligated to protect your data.
                  </p>
  
                  <div class="about-divider"></div>
  
                  <h3>Data Protection Rights</h3>
                  <p>You have the right to:</p>
                  <ul>
                      <li>Access, correct, or delete your personal data.</li>
                      <li>Restrict or object to data processing.</li>
                      <li>Request data portability.</li>
                  </ul>
                  <p>To exercise these rights, contact us at <a href="mailto:privacy@bharatjewellers.ca">privacy@bharatjewellers.ca</a>.</p>
  
                  <div class="about-divider"></div>
  
                  <h3>Changes to Privacy Policy</h3>
                  <p>We reserve the right to update this Privacy Policy at any time. Changes will be posted on this page.</p>
  
                  <div class="about-divider"></div>
  
                  <h3>Contact Us</h3>
                  <p>
                      Surrey Location: <a href="mailto:surrey@bharatjewellers.ca">surrey@bharatjewellers.ca</a><br>
                      Calgary Location: <a href="mailto:calgary@bharatjewellers.ca">calgary@bharatjewellers.ca</a>
                  </p>
              </div>
          </section>
</BaseLayout>
