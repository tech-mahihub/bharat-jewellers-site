---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Collections - Bharat Jewellers | Bridal, Diamond & Gold Jewellery";
const pageDescription = "Explore Bharat Jewellers";
const canonicalURL = "https://bharatjewellers.ca/collections/";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const ogTitle = "Collections - Bharat Jewellers | Bridal, Diamond & Gold Jewellery";
const keywords = "Bharat Jewellers collections, gold jewellery, diamond jewellery, bridal sets, custom jewellery, Indian jewellery Surrey Calgary Edmonton";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
>
  <Fragment slot="head">
    <!-- Fonts -->
        <!-- Google tag (gtag.js) -->
  </Fragment>
  <section class="section collections-hero">
              <div class="content-wrap collections-hero-inner">
                  <h1>Our Jewellery Collections</h1>
                  <p>Explore our complete range of fine jewellery</p>
                  <div class="hero-divider"></div>
              </div>
          </section>
  
          <section class="section collections-grid-section">
              <div class="content-wrap">
                  <div class="category-grid">
                      <a class="category-card" href="/gold-jewellery/">
                          <div class="category-image">
                              <img src="/assets/images/Homepage/Gold-Jewellery-Collections.webp" alt="Gold Jewellery">
                          </div>
                          <h3>Gold Jewellery</h3>
                          <p>Elegant pieces crafted in 22K gold</p>
                      </a>
                      <a class="category-card" href="/diamond-jewellery/">
                          <div class="category-image">
                              <img src="/assets/images/Homepage/Diamond-Jewellery-Collections.webp" alt="Diamond Jewellery">
                          </div>
                          <h3>Diamond Jewellery</h3>
                          <p>Refined brilliance for modern luxury</p>
                      </a>
                      <a class="category-card" href="/bridal-sets/">
                          <div class="category-image">
                              <img src="/assets/images/Homepage/Gold-Bridal-Sets.webp" alt="Bridal Sets">
                          </div>
                          <h3>Bridal Sets</h3>
                          <p>Complete sets for your special day</p>
                      </a>
                      <a class="category-card" href="/custom-jewellery/">
                          <div class="category-image">
                              <img src="/assets/images/Homepage/Custom-Jewellery-Surrey-BC.webp" alt="Custom Jewellery">
                          </div>
                          <h3>Custom Jewellery</h3>
                          <p>Bring your unique vision to life</p>
                      </a>
                  </div>
              </div>
          </section>
  
          <section class="section about-story">
              <div class="content-wrap">
                  <div class="about-story-grid">
                      <div class="about-story-text">
                          <div>
                              <h3>Craftsmanship &amp; Fine Materials</h3>
                              <p>Our 22K gold jewellery is shaped with precision, balancing timeless tradition with a luminous, contemporary finish.</p>
                          </div>
                          <div class="about-divider"></div>
                          <div>
                              <p>Every diamond is selected for clarity and brilliance, then set by skilled hands to elevate its natural fire.</p>
                          </div>
                          <div class="about-divider"></div>
                          <div>
                              <p>From the first sketch to the final polish, each piece is handcrafted to feel exquisite, enduring, and unmistakably yours.</p>
                          </div>
                      </div>
                      <div class="about-story-image">
                          <img src="/assets/images/Homepage/bharat-jewellers-custom-gold-jewellery-design.webp" alt="Handcrafted jewellery finishing">
                      </div>
                  </div>
              </div>
          </section>
  
          <section class="section milestone-section">
              <div class="content-wrap">
                  <div class="section-title milestone-title">
                      <h2>Jewellery for Every Occasion</h2>
                  </div>
                  <div class="milestone-grid">
                      <article class="milestone-card">
                          <div class="milestone-image">
                              <img src="/assets/images/Homepage/bharat-jewellers-bridal-gold-necklace-set.webp" alt="Weddings and bridal moments">
                          </div>
                          <h3>Weddings &amp; Bridal Moments</h3>
                          <p>Timeless gold and diamond jewellery crafted to honour weddings, engagements, and cherished traditions.</p>
                      </article>
                      <article class="milestone-card">
                          <div class="milestone-image">
                              <img src="/assets/images/Homepage/bharat-jewellers-diamond-jewellery-gifting.webp" alt="Celebrations and gifting">
                          </div>
                          <h3>Celebrations &amp; Gifting</h3>
                          <p>Mark birthdays and anniversaries with refined pieces designed to be treasured for years to come.</p>
                      </article>
                      <article class="milestone-card">
                          <div class="milestone-image">
                              <img src="/assets/images/Homepage/bharat-jewellers-everyday-gold-necklace-women.webp" alt="Everyday elegance">
                          </div>
                          <h3>Everyday Elegance</h3>
                          <p>Graceful designs for daily wear, blending subtle sophistication with lasting comfort.</p>
                      </article>
                      <article class="milestone-card">
                          <div class="milestone-image">
                              <img src="/assets/images/Homepage/bharat-jewellers-custom-gold-jewellery-design.webp" alt="Custom creations">
                          </div>
                          <h3>Custom Creations</h3>
                          <p>Collaborate with our artisans to bring personal stories to life through bespoke jewellery.</p>
                      </article>
                  </div>
              </div>
          </section>
  
          <section class="section about-features">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Why Choose Bharat Jewellers</h2>
                  </div>
                  <div class="about-feature-grid">
                      <div class="about-feature-card">
                          <div class="about-icon">
                              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l3 5 5 3-5 3-3 5-3-5-5-3 5-3 3-5z"/></svg>
                          </div>
                          <h3>Trusted Since 1998</h3>
                          <p>Decades of heritage and reputation.</p>
                      </div>
                      <div class="about-feature-card">
                          <div class="about-icon">
                              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3l7 3v6c0 4.2-3 7.8-7 9-4-1.2-7-4.8-7-9V6l7-3z"/><path d="M9.5 12.5l2 2 4-4"/></svg>
                          </div>
                          <h3>Certified Gold &amp; Diamonds</h3>
                          <p>Authenticity you can trust.</p>
                      </div>
                      <div class="about-feature-card">
                          <div class="about-icon">
                              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 20h16"/><path d="M6 16l6-6 6 6"/><path d="M7 7h10"/></svg>
                          </div>
                          <h3>Expert Craftsmanship</h3>
                          <p>Meticulous detail and finishing.</p>
                      </div>
                      <div class="about-feature-card">
                          <div class="about-icon">
                              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v18"/><path d="M5 10h14"/><path d="M7 6h10"/></svg>
                          </div>
                          <h3>Multiple Store Locations</h3>
                          <p>Visit us in Surrey, Calgary, and Edmonton.</p>
                      </div>
                  </div>
              </div>
          </section>
  
          <section class="section location-section">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Visit Bharat Jewellers – Surrey, Calgary &amp; Edmonton</h2>
                  </div>
                  <div class="location-grid">
                      <article class="location-card">
                          <a href="/surrey/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Surrey-Store1.webp" alt="Bharat Jewellers Surrey">
                          </a>
                          <h3>Surrey</h3>
                          <p>155-8120 128 Street, Surrey, British Columbia V3W 1R1, Canada
                            <br>
                            <br>
                            <a href="tel:+16045931111">+1 (604) 593-1111</a>
                            <br>
                            <a href="mailto:surrey@bharatjewellers.ca">surrey@bharatjewellers.ca</a></p>
                          <a class="location-link" href="/surrey/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/calgary/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Calgary.webp" alt="Bharat Jewellers Calgary">
                          </a>
                          <h3>Calgary</h3>
                          <p>Cityscape Landing Plaza, 4310 104 Ave NE #1130, Calgary, AB T3N 1W1, Canada
                            <br><br>
                            <a href="tel:+14035580455">+1 403-558-0455</a>
                            <br>
                            <a href="mailto:calgary@bharatjewellers.ca">calgary@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/calgary/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/edmonton/" class="location-image">
                              <img src="/assets/images/Locations/Jewelry-Stores-Edmonton-1.webp" alt="Bharat Jewellers Edmonton">
                          </a>
                          <h3>Edmonton</h3>
                          <p>9358 34 Ave NW, Edmonton, AB T6E 5X8, Canada
                            <br><br>
                            <a href="tel:+17802626111">+1 780-262-6111</a>
                            <br>
                            <a href="mailto:edmonton@bharatjewellers.ca">edmonton@bharatjewellers.ca</a></p>
                          <a class="location-link" href="/edmonton/">View Store</a>
                      </article>
                  </div>
              </div>
          </section>
  
          <section class="section about-cta">
              <div class="content-wrap">
                  <div class="about-cta-card">
                      <h2>Discover Jewellery Crafted for a Lifetime</h2>
                      <p>Explore our collections in person and experience the artistry, precision, and heritage behind every piece.</p>
                      <a class="btn-primary" href="/contact/">Visit Our Store</a>
                  </div>
              </div>
          </section>
</BaseLayout>
