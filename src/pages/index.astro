---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogCard from "../components/blog/BlogCard.astro";
import { getCollection } from "astro:content";
const pageTitle = "Bharat Jewellers | Gold & Diamond Jewellery Canada";
const pageDescription = "Bharat Jewellers - Premium luxury jewellery store offering exquisite gold, diamond, and bridal collections. Established jewellers crafting timeless pieces since decades.";
const canonicalURL = "https://bharatjewellers.ca/";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const ogTitle = "Bharat Jewellers - Premium Luxury Jewellery | Gold & Diamond Collections";
const keywords = "Bharat Jewellers, gold jewellery, diamond jewellery, bridal jewellery, custom jewellery Surrey Calgary Edmonton, luxury jewellery Canada";
const siteVerification = "KbW8p7WJtrieLKGeFCJGMHzrcnOqCphaQeuNQpwUOAE";
const latestBlogPosts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
>
  <Fragment slot="head">
    <script type="application/ld+json">{"@context":"https://schema.org","@type":"Organization","name":"Bharat Jewellers","url":"https://bharatjewellers.ca","logo":"https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp","sameAs":["https://www.instagram.com/bharatjewellerscalgary/","https://www.facebook.com/BharatJeweller/"],"address":[{"@type":"PostalAddress","streetAddress":"155-8120 128 Street","addressLocality":"Surrey","addressRegion":"BC","postalCode":"V3W 1R1"},{"@type":"PostalAddress","streetAddress":"4310 104 Ave NE #1130","addressLocality":"Calgary","addressRegion":"AB","postalCode":"T3N 1W1"},{"@type":"PostalAddress","streetAddress":"9358 34 Ave NW","addressLocality":"Edmonton","addressRegion":"AB","postalCode":"T6E 5X8"}]}</script>
        <!-- Fonts -->
        <!-- Google tag (gtag.js) -->
  </Fragment>
  <!-- ================= HERO ================= -->
          <section class="hero">
              <div class="hero-overlay"></div>
              <div class="hero-inner content-wrap">
                  <h1>Gold &amp; Diamond Jewellery Designed for Every Occasion</h1>
