          <section class="section category-section">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Explore Our Gold, Diamond &amp; Bridal Jewellery Collections</h2>
                  </div>
                  <div class="category-grid">
                      <a class="category-card" href="/gold-jewellery/">
                          <div class="category-image">
                              <img src="/assets/images/Homepage/Gold-Jewellery-Collections.webp" alt="Gold Jewellery Collections">
                          </div>
                          <h3>Gold Jewellery</h3>
                          <p>Elegant pieces crafted in 22K gold</p>
                      </a>
                      <a class="category-card" href="/diamond-jewellery/">
                          <div class="category-image">
                              <img src="/assets/images/Homepage/Diamond-Jewellery-Collections.webp" alt="Diamond Jewellery Collections">
                          </div>
                          <h3>Diamond Jewellery</h3>
                          <p>Refined brilliance for modern luxury</p>
                      </a>
                      <a class="category-card" href="/bridal-sets/">
                          <div class="category-image">
                              <img src="/assets/images/Homepage/Gold-Bridal-Sets.webp" alt="Gold Bridal Sets">
                          </div>
