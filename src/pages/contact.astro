<script is:inline>
  (function () {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    function closeItem(item) {
      const answer = item.querySelector('.faq-answer');
      const trigger = item.querySelector('.faq-question');
      if (!answer || !trigger) return;
      item.classList.remove('active');
      trigger.setAttribute('aria-expanded', 'false');
      answer.style.maxHeight = '0px';
    }

    function openItem(item) {
      const answer = item.querySelector('.faq-answer');
      const trigger = item.querySelector('.faq-question');
      if (!answer || !trigger) return;
      item.classList.add('active');
      trigger.setAttribute('aria-expanded', 'true');
      answer.style.maxHeight = answer.scrollHeight + 'px';
    }

    items.forEach((item, idx) => {
      const trigger = item.querySelector('.faq-question');
      const answer = item.querySelector('.faq-answer');
      if (!trigger || !answer) return;

      answer.style.overflow = 'hidden';
      answer.style.transition = 'max-height 280ms ease';
      answer.style.maxHeight = item.classList.contains('active') ? answer.scrollHeight + 'px' : '0px';
      trigger.addEventListener('click', () => {
        const isActive = item.classList.contains('active');
        items.forEach(closeItem);
        if (!isActive) openItem(item);
      });

      if (idx !== 0) closeItem(item);
    });

    const firstActive = items.find((item) => item.classList.contains('active'));
    if (firstActive) openItem(firstActive);
  })();
</script>
