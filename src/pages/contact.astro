---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Contact Bharat Jewellers | Jewellery Store Support";
const pageDescription = "Contact Bharat Jewellers – Surrey, Calgary, Edmonton. Visit our stores, call, or send a message. We";
const canonicalURL = "https://bharatjewellers.ca/contact/";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const ogTitle = "Contact Us - Bharat Jewellers";
const keywords = "contact Bharat Jewellers, jewellery store Surrey Calgary Edmonton, custom jewellery inquiry, gold diamond consultation";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
const htmlClass = "dark";
const bodyClass = "bg-background-dark font-sans text-white contact-page";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
  htmlClass={htmlClass}
  bodyClass={bodyClass}
>
  <Fragment slot="head">
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
    <style>
        .material-symbols-outlined {
          font-variation-settings:
            'FILL' 0,
            'wght' 300,
            'GRAD' 0,
            'opsz' 24
        }
      </style>
    <script id="tailwind-config">
        window.tailwind = window.tailwind || {};
        window.tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "primary": "#c9a769",
                "background-light": "#f8f7f6",
                "background-dark": "#0a0a0a"
              },
              fontFamily: {
                "display": ["Noto Serif", "serif"],
                "sans": ["Noto Sans", "sans-serif"]
              },
              borderRadius: {
                "DEFAULT": "1rem",
                "lg": "2rem",
                "xl": "3rem",
                "full": "9999px"
              }
            }
          }
        };
      </script>
      <!-- Google tag (gtag.js) -->
  </Fragment>
  <div class="flex-1 py-10 contact-main">
  <!-- HeroSection -->
  <section class="contact-hero-section" aria-label="Contact Hero">
    <div class="content-wrap">
    <div class="contact-hero">
    <div class="contact-hero-content container">
    <h1 class="contact-hero-title">Contact Bharat Jewellers</h1>
    <h2 class="contact-hero-subtitle">Surrey, Calgary &amp; Edmonton – We’re Here to Assist You</h2>
    <div class="contact-divider underline"></div>
    </div>
    </div>
    </div>
  </section>
  
  <div class="content-wrap contact-page-stack">
  <!-- Contact Form Section -->
  <section class="contact-section">
  <div class="contact-wrapper">
  <div class="contact-left">
  <h2 class="contact-left-title">Send Us a Message</h2>
  <p class="contact-left-desc">Have a question about gold, diamond or bridal jewellery? Need a custom design? Fill out the form – our Surrey, Calgary &amp; Edmonton teams will get back to you promptly.</p>
  <div class="contact-support-image-wrap">
  <img class="contact-support-image" src="/assets/images/Contact/Bridal-Jewelry-Shopping-Tips.webp" alt="Jewellery craftsmanship detail">
  </div>
  </div>
  <div class="form-card contact-form">
  <form class="contact-form-fields" action="https://formspree.io/f/mpqrppyj" method="POST">
  <input type="hidden" name="_subject" value="Bharat Jewellers Contact">
  <input type="text" name="_gotcha" style="display:none">
  <div class="contact-form-grid">
  <input name="name" class="contact-input" placeholder="Your Name" type="text"/>
  <input name="email" class="contact-input" placeholder="Email Address" type="email"/>
  <input name="phone" class="contact-input" placeholder="Phone Number" type="tel"/>
  <select name="location" class="contact-input">
  <option class="bg-background-dark text-white/50">Select a Store</option>
  <option class="bg-background-dark text-white">Surrey</option>
  <option class="bg-background-dark text-white">Calgary</option>
  <option class="bg-background-dark text-white">Edmonton</option>
  </select>
  </div>
  <textarea name="message" class="contact-input contact-textarea" placeholder="Your Message" rows="4"></textarea>
  <button class="contact-submit-btn" type="submit">Send Message</button>
  <div class="contact-form-status" aria-live="polite"></div>
  </form>
  </div>
  </div>
  </section>
  <!-- Visit Our Stores (reusable component – same as homepage, heading for contact page) -->
  <section class="section location-section" id="contact-store-locations" aria-labelledby="contact-store-heading">
      <div id="store-locations-inject" data-heading="Visit Our Stores"></div>
  </section>
  <!-- Why Contact Bharat Jewellers (text left, image right) -->
  <section class="section why-contact two-column category-seo" id="why-contact-section" aria-labelledby="why-contact-heading">
      <div class="content-wrap why-contact-wrap">
          <div class="text-content">
              <h2 id="why-contact-heading" class="category-seo-heading">Why Contact Bharat Jewellers?</h2>
              <ul class="category-seo-why-list">
                  <li><strong>Personalized jewellery consultation</strong> — Discuss your style, occasion, and budget with our experts in a relaxed, one-on-one setting.</li>
                  <li><strong>Certified gold &amp; diamond jewellery guidance</strong> — Get clear, honest advice on purity, certification, and value across our collections.</li>
                  <li><strong>Bridal and wedding jewellery expertise</strong> — From engagement rings to full bridal sets, we help you choose and customize pieces for your big day.</li>
                  <li><strong>Trusted jewellery store in Surrey, Calgary &amp; Edmonton</strong> — Visit any of our three locations for the same high standards and friendly service.</li>
                  <li><strong>Friendly in-store customer experience</strong> — Walk-ins welcome; no appointment required. Our team is here to assist with selections, sizing, and care.</li>
              </ul>
          </div>
          <div class="image-content">
              <div class="seo-section-image-wrap">
                  <img class="seo-section-image" src="/assets/images/Homepage/bharat-jewellers-custom-gold-jewellery-design.webp" alt="Elegant jewellery consultation at Bharat Jewellers">
              </div>
          </div>
      </div>
  </section>
  <!-- FAQ Section -->
  <section class="faq-section" aria-labelledby="contact-faq-heading">
  <h2 id="contact-faq-heading" class="faq-title">Frequently Asked Questions</h2>
  <div class="faq-list">
  <div class="faq-item active">
  <button class="faq-question" type="button" aria-expanded="true">
  <span>What is the best way to contact the Surrey store?</span>
  <span class="icon" aria-hidden="true">▼</span>
  </button>
  <div class="faq-answer">
  <p>For the fastest response, we recommend calling the Surrey store directly at +1 (604) 593-1111 during business hours. You can also visit any store for dedicated guidance.</p>
  </div>
  </div>
  <div class="faq-item">
  <button class="faq-question" type="button" aria-expanded="false">
  <span>Do you offer bridal guidance in-store?</span>
  <span class="icon" aria-hidden="true">▼</span>
  </button>
  <div class="faq-answer">
  <p>Yes, our specialists provide personalized bridal guidance in-store, and walk-ins are always welcome.</p>
  </div>
  </div>
  <div class="faq-item">
  <button class="faq-question" type="button" aria-expanded="false">
  <span>How quickly do you reply to messages?</span>
  <span class="icon" aria-hidden="true">▼</span>
  </button>
  <div class="faq-answer">
  <p>We strive to respond to all inquiries submitted through our contact form within one business day. For urgent matters, please call your nearest store directly.</p>
  </div>
  </div>
  <div class="faq-item">
  <button class="faq-question" type="button" aria-expanded="false">
  <span>Do I need an appointment before visiting?</span>
  <span class="icon" aria-hidden="true">▼</span>
  </button>
  <div class="faq-answer">
  <p>No appointment is necessary. Walk-ins are always welcome at all three locations — Surrey, Calgary, and Edmonton. Our team is ready to assist you with browsing, trying on pieces, and answering questions during regular store hours.</p>
  </div>
  </div>
  <div class="faq-item">
  <button class="faq-question" type="button" aria-expanded="false">
  <span>Do you offer custom jewellery consultations?</span>
  <span class="icon" aria-hidden="true">▼</span>
  </button>
  <div class="faq-answer">
  <p>Yes. We offer dedicated custom jewellery consultations where you can discuss your design ideas, materials, and timeline with our artisans. Visit any store or contact us through the form to get started.</p>
  </div>
  </div>
  <div class="faq-item">
  <button class="faq-question" type="button" aria-expanded="false">
  <span>What payment methods are accepted in-store?</span>
  <span class="icon" aria-hidden="true">▼</span>
  </button>
  <div class="faq-answer">
  <p>We accept major credit and debit cards, bank transfers, and cash. For larger purchases, we can discuss flexible payment options. Please ask our staff at any location for details.</p>
  </div>
  </div>
  <div class="faq-item">
  <button class="faq-question" type="button" aria-expanded="false">
  <span>Can I check live gold rates at your stores?</span>
  <span class="icon" aria-hidden="true">▼</span>
  </button>
  <div class="faq-answer">
  <p>Yes. You can check live gold rates on our website or ask our staff in-store for current rates. We also display and explain rates when you visit, so you can make informed decisions.</p>
  </div>
  </div>
  <div class="faq-item">
  <button class="faq-question" type="button" aria-expanded="false">
  <span>Do all locations provide bridal jewellery consultation?</span>
  <span class="icon" aria-hidden="true">▼</span>
  </button>
  <div class="faq-answer">
  <p>Yes. Bridal jewellery consultation is available at Surrey, Calgary, and Edmonton. Our specialists help with engagement rings, bridal sets, and custom pieces for your wedding day at every location.</p>
  </div>
  </div>
  </div>
  </section>
  </div>
  </div>
  <Fragment slot="afterMain">
    <script is:inline src="/assets/js/store-locations.js"></script>
    <script is:inline>
  (function () {
    const items = Array.from(document.querySelectorAll('.faq-item'));
    if (!items.length) return;

    function closeItem(item) {
      const answer = item.querySelector('.faq-answer');
      const trigger = item.querySelector('.faq-question');
      if (!answer || !trigger) return;
      item.classList.remove('active');
      trigger.setAttribute('aria-expanded', 'false');
      answer.style.maxHeight = '0px';
    }

    function openItem(item) {
      const answer = item.querySelector('.faq-answer');
      const trigger = item.querySelector('.faq-question');
      if (!answer || !trigger) return;
      item.classList.add('active');
      trigger.setAttribute('aria-expanded', 'true');
      answer.style.maxHeight = answer.scrollHeight + 'px';
    }

    items.forEach((item, idx) => {
      const trigger = item.querySelector('.faq-question');
      const answer = item.querySelector('.faq-answer');
      if (!trigger || !answer) return;

      answer.style.overflow = 'hidden';
      answer.style.transition = 'max-height 280ms ease';
      answer.style.maxHeight = item.classList.contains('active') ? answer.scrollHeight + 'px' : '0px';
      trigger.addEventListener('click', () => {
        const isActive = item.classList.contains('active');
        items.forEach(closeItem);
        if (!isActive) openItem(item);
      });

      if (idx !== 0) closeItem(item);
    });

    const firstActive = items.find((item) => item.classList.contains('active'));
    if (firstActive) openItem(firstActive);
  })();
</script>
  </Fragment>
</BaseLayout>
