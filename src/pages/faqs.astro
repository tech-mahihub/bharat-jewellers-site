            </div>
        </section>

        <!-- ================= FAQ ACCORDION ================= -->
        <section class="section faq-section">
            <div class="content-wrap">
                <div class="faq-list">
                    <div class="faq-item">
                        <button class="faq-question" type="button" aria-expanded="false">
                            <span>Do you offer custom jewellery design?</span>
                            <span class="faq-toggle" aria-hidden="true"></span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes. Our in-house designers work with you to create bespoke pieces tailored to your vision, budget, and timeline.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" type="button" aria-expanded="false">
                            <span>What purity of gold do you carry?</span>
                            <span class="faq-toggle" aria-hidden="true"></span>
                        </button>
                        <div class="faq-answer">
                            <p>We offer 22K and 24K gold jewellery with hallmarked purity and transparent pricing.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" type="button" aria-expanded="false">
                            <span>Do you provide jewellery repair and cleaning?</span>
                            <span class="faq-toggle" aria-hidden="true"></span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes. We provide professional cleaning, polishing, resizing, and repairs to restore your pieces.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" type="button" aria-expanded="false">
                            <span>How do I get help selecting jewellery?</span>
                            <span class="faq-toggle" aria-hidden="true"></span>
                        </button>
                        <div class="faq-answer">
                            <p>Visit any store for personalized guidance or reach out through our Contact page.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" type="button" aria-expanded="false">
                            <span>Do you offer bridal sets and wedding jewellery?</span>
                            <span class="faq-toggle" aria-hidden="true"></span>
                        </button>
                        <div class="faq-answer">
                            <p>We carry an extensive bridal collection and offer curated guidance to help you select the perfect set.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" type="button" aria-expanded="false">
                            <span>Can I exchange or upgrade my jewellery?</span>
                            <span class="faq-toggle" aria-hidden="true"></span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes. We offer exchange and upgrade options based on item condition and documentation. Please visit a store for details.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" type="button" aria-expanded="false">
                            <span>Where are your store locations?</span>
                            <span class="faq-toggle" aria-hidden="true"></span>
                        </button>
                        <div class="faq-answer">
                            <p>We are located in Surrey, Calgary, and Edmonton. Visit the location pages for addresses and contact details.</p>
                        </div>
                    </div>
                    <div class="faq-item">
                        <button class="faq-question" type="button" aria-expanded="false">
                            <span>Do you certify diamonds?</span>
                            <span class="faq-toggle" aria-hidden="true"></span>
                        </button>
                        <div class="faq-answer">
                            <p>Yes. Our diamond jewellery includes certification and detailed documentation for clarity and confidence.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ================= CTA ================= -->
        <section class="section about-cta">
