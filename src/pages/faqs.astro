---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Jewellery FAQs | Bharat Jewellers Customer Help";
const pageDescription = "Frequently asked questions about Bharat Jewellers, our services, and store experience.";
const canonicalURL = "https://bharatjewellers.ca/faqs/";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const ogTitle = "FAQs - Bharat Jewellers";
const keywords = "Bharat Jewellers FAQ, jewellery questions, custom jewellery, gold diamond care, store Surrey Calgary Edmonton";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
>
  <Fragment slot="head">
    <!-- Fonts -->
        <!-- Google tag (gtag.js) -->
  </Fragment>
  <!-- ================= HERO ================= -->
          <section class="section faq-hero">
              <div class="content-wrap">
                  <div class="section-title">
                      <h1>Bharat Jewellers FAQs – Gold, Diamond &amp; Bridal Jewellery</h1>
                      <div class="hero-divider"></div>
                  </div>
                  <p class="about-intro">Answers to common questions about our jewellery, services, and stores.</p>
              </div>
          </section>
  
          <!-- ================= FAQ ACCORDION ================= -->
          <section class="section faq-section">
              <div class="content-wrap">
                  <div class="faq-list">
                      <div class="faq-item">
                          <button class="faq-question" type="button" aria-expanded="false">
                              <span>Do you offer custom jewellery design?</span>
                              <span class="faq-toggle" aria-hidden="true"></span>
                          </button>
                          <div class="faq-answer">
                              <p>Yes. Our in-house designers work with you to create bespoke pieces tailored to your vision, budget, and timeline.</p>
                          </div>
                      </div>
                      <div class="faq-item">
                          <button class="faq-question" type="button" aria-expanded="false">
                              <span>What purity of gold do you carry?</span>
                              <span class="faq-toggle" aria-hidden="true"></span>
                          </button>
                          <div class="faq-answer">
                              <p>We offer 22K and 24K gold jewellery with hallmarked purity and transparent pricing.</p>
                          </div>
                      </div>
                      <div class="faq-item">
                          <button class="faq-question" type="button" aria-expanded="false">
                              <span>Do you provide jewellery repair and cleaning?</span>
                              <span class="faq-toggle" aria-hidden="true"></span>
                          </button>
                          <div class="faq-answer">
                              <p>Yes. We provide professional cleaning, polishing, resizing, and repairs to restore your pieces.</p>
                          </div>
                      </div>
                      <div class="faq-item">
                          <button class="faq-question" type="button" aria-expanded="false">
                              <span>How do I get help selecting jewellery?</span>
                              <span class="faq-toggle" aria-hidden="true"></span>
                          </button>
                          <div class="faq-answer">
                              <p>Visit any store for personalized guidance or reach out through our Contact page.</p>
                          </div>
                      </div>
                      <div class="faq-item">
                          <button class="faq-question" type="button" aria-expanded="false">
                              <span>Do you offer bridal sets and wedding jewellery?</span>
                              <span class="faq-toggle" aria-hidden="true"></span>
                          </button>
                          <div class="faq-answer">
                              <p>We carry an extensive bridal collection and offer curated guidance to help you select the perfect set.</p>
                          </div>
                      </div>
                      <div class="faq-item">
                          <button class="faq-question" type="button" aria-expanded="false">
                              <span>Can I exchange or upgrade my jewellery?</span>
                              <span class="faq-toggle" aria-hidden="true"></span>
                          </button>
                          <div class="faq-answer">
                              <p>Yes. We offer exchange and upgrade options based on item condition and documentation. Please visit a store for details.</p>
                          </div>
                      </div>
                      <div class="faq-item">
                          <button class="faq-question" type="button" aria-expanded="false">
                              <span>Where are your store locations?</span>
                              <span class="faq-toggle" aria-hidden="true"></span>
                          </button>
                          <div class="faq-answer">
                              <p>We are located in Surrey, Calgary, and Edmonton. Visit the location pages for addresses and contact details.</p>
                          </div>
                      </div>
                      <div class="faq-item">
                          <button class="faq-question" type="button" aria-expanded="false">
                              <span>Do you certify diamonds?</span>
                              <span class="faq-toggle" aria-hidden="true"></span>
                          </button>
                          <div class="faq-answer">
                              <p>Yes. Our diamond jewellery includes certification and detailed documentation for clarity and confidence.</p>
                          </div>
                      </div>
                  </div>
              </div>
          </section>
  
          <!-- ================= CTA ================= -->
          <section class="section about-cta">
              <div class="content-wrap">
                  <div class="about-cta-card">
                      <h2>Still Have Questions?</h2>
                      <p>Our jewellery consultants are here to help you with personalized guidance.</p>
                      <a class="btn-primary" href="/contact/">Contact Us</a>
                  </div>
              </div>
          </section>
</BaseLayout>
