---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Thank You - Bharat Jewellers";
const pageDescription = "Thank you for contacting Bharat Jewellers. We have received your message and will get back to you soon.";
const canonicalURL = "https://bharatjewellers.ca/thank-you/";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
const htmlClass = "dark";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  siteVerification={siteVerification}
  htmlClass={htmlClass}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
    <style>
        .material-symbols-outlined {
          font-variation-settings:
            'FILL' 0,
            'wght' 300,
            'GRAD' 0,
            'opsz' 24
        }
      </style>
    <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              colors: {
                "primary": "#c9a769",
                "background-light": "#f8f7f6",
                "background-dark": "#0a0a0a",
              },
              fontFamily: {
                "display": ["Noto Serif", "serif"],
                "sans": ["Noto Sans", "sans-serif"]
              },
              borderRadius: {
                "DEFAULT": "1rem",
                "lg": "2rem",
                "xl": "3rem",
                "full": "9999px"
              },
            },
          },
        }
      </script>
      <!-- Google tag (gtag.js) -->
  </Fragment>
  <!-- ================= HERO (same as homepage) ================= -->
          <section class="hero">
              <div class="hero-overlay"></div>
              <div class="hero-inner content-wrap">
                  <h1>Thank You</h1>
                  <p class="hero-sub">We've received your message and will get back to you soon.</p>
                  <a class="btn-primary hero-cta" href="/">Back to Home</a>
              </div>
          </section>
</BaseLayout>
