<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
  htmlClass={htmlClass}
  bodyClass={bodyClass}
