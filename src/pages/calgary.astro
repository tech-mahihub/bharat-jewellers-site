    <script>
      const locationVideos = Array.from(document.querySelectorAll(".location-video"));
      locationVideos.forEach((video) => {
        video.addEventListener("play", () => {
          locationVideos.forEach((otherVideo) => {
            if (otherVideo !== video && !otherVideo.paused) {
              otherVideo.pause();
            }
          });
        });
      });
    </script>
