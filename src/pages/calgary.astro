        <script>
          window.tailwind = window.tailwind || {};
          window.tailwind.config = {
            darkMode: "class",
            corePlugins: {
              preflight: false,
            },
            theme: {
              extend: {
                colors: {
                  primary: "#c9a769",
                  "background-light": "#f8f7f6",
                  "background-dark": "#050505",
                },
                fontFamily: {
                  display: ["Noto Serif", "serif"],
