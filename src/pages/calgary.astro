---
import BaseLayout from "../layouts/BaseLayout.astro";
import StoreInfoSection from "../components/location/StoreInfoSection.astro";
const pageTitle = "Bharat Jewellers – Calgary Store Location";
const pageDescription = "Visit Bharat Jewellers Calgary at Cityscape Landing Plaza. Gold, diamond & bridal jewellery. Open Mon-Sat 10am-8pm. Call (403) 558-0455.";
const canonicalURL = "https://bharatjewellers.ca/calgary/";
const ogImage = "https://bharatjewellers.ca/assets/images/Locations/Bharat-Jewellers-Calgary.webp";
const ogType = "website";
const ogTitle = "Bharat Jewellers – Calgary Store Location";
const keywords = "Bharat Jewellers Calgary, jewellery store Calgary, gold jewellery Calgary, diamond jewellery Calgary, Indian jewellery Calgary";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
const htmlClass = "dark";
const bodyClass = "bg-background-dark font-sans text-[#F5F5F5] location-page";
