---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Bridal Sets Collection - Bharat Jewellers";
const pageDescription = "Explore Bharat Jewellers";
const canonicalURL = "https://bharatjewellers.ca/bridal-sets";
const ogImage = "https://bharatjewellers.ca/assets/images/Homepage/Gold-Bridal-Sets.webp";
const ogType = "website";
const ogTitle = "Bridal Sets Collection - Bharat Jewellers";
const keywords = "Bridal jewellery collection, bridal sets, polki sets, wedding jewellery, Bharat Jewellers";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
>
  <Fragment slot="head">
    <!-- Fonts -->
        <!-- Google tag (gtag.js) -->
        <script>
          window.__BJ_CATEGORY__ = 'bridal-sets';
        </script>
  </Fragment>
  <section class="section category-hero" id="category-hero">
              <div class="category-hero-overlay"></div>
              <div class="category-hero-inner content-wrap">
                  <span class="category-badge" id="category-badge">Bridal Sets</span>
                  <h1 id="category-title">Bridal Sets</h1>
                  <p class="category-intro" id="category-intro">
                      Celebrate your most cherished moments with bridal sets crafted in gold and diamonds.
                  </p>
              </div>
          </section>
  
          <section class="section category-filter-section">
              <div class="content-wrap">
                  <div class="category-filters" id="category-filters"></div>
              </div>
          </section>
  
          <section class="section category-grid-section">
              <div class="content-wrap">
                  <div class="jewellery-grid" id="jewellery-grid"></div>
              </div>
          </section>
  
          <section class="section category-highlight">
              <div class="category-highlight-inner content-wrap" id="category-highlight">
                  <div class="category-highlight-overlay"></div>
                  <div class="category-highlight-text">
                      <h2 id="category-highlight-title">Discover Your Dream Bridal Set</h2>
                      <p id="category-highlight-text">Celebrate your most cherished moments with radiant sets crafted for timeless elegance.</p>
                      <a class="btn-primary" id="category-highlight-button" href="/contact/">Contact Us</a>
                  </div>
              </div>
          </section>
  
          <section class="section category-details">
              <div class="content-wrap">
                  <div class="category-details-grid">
                      <div class="category-details-text">
                          <h2 id="category-details-title">Bridal Craftsmanship, Elevated</h2>
                          <p id="category-details-text">Our bridal sets blend heritage artistry with refined modern accents for unforgettable moments.</p>
                      </div>
                      <div class="category-blurb-grid" id="category-blurb-grid"></div>
                  </div>
              </div>
          </section>
  
          <section class="section about-category two-column category-seo" id="seo-about-section" aria-labelledby="seo-about-heading">
              <div class="content-wrap about-category-wrap">
                  <div class="text-content">
                      <h2 id="seo-about-heading" class="category-seo-heading">About <span id="seo-category-name">Bridal Sets</span></h2>
                      <div class="category-seo-about-content">
                          <p id="seo-about-p1">
                              Bharat Jewellers offers a premium bridal jewellery collection in Surrey, blending handcrafted gold and diamond sets with traditional and contemporary design. Each piece is certified jewellery, crafted for weddings and special occasions.
                          </p>
                          <p id="seo-about-p2">
                              From necklace sets and polki to reception and ceremony wear, our bridal collection delivers luxury jewellery tailored to your style. Visit our jewellery store in Surrey to try on sets and receive a personalized experience.
                          </p>
                          <p id="seo-about-p3">
                              As a trusted jeweller in Surrey, we combine expert craftsmanship with certified materials. Whether you need a complete bridal set or custom touches, our team helps you find the perfect premium jewellery for your day.
                          </p>
                      </div>
                  </div>
                  <div class="image-content">
                      <div class="seo-section-image-wrap">
                          <img id="seo-about-image" src="/assets/images/Homepage/Gold-Bridal-Sets.webp" alt="Bridal Sets – Bharat Jewellers" class="seo-section-image">
                      </div>
                  </div>
              </div>
          </section>
  
          <section class="section why-choose two-column reverse category-seo" id="seo-why-section" aria-labelledby="seo-why-heading">
              <div class="content-wrap why-choose-wrap">
                  <div class="image-content">
                      <div class="seo-section-image-wrap">
                          <img id="seo-why-image" src="/assets/images/Collections/bridal-gold-diamond-jewellery-sets-bharat-jewellers.webp" alt="Why choose Bharat Jewellers for Bridal Sets" class="seo-section-image">
                      </div>
                  </div>
                  <div class="text-content">
                      <h2 id="seo-why-heading" class="category-seo-heading">Why Choose <span id="seo-brand-name">Bharat Jewellers</span> for <span id="seo-why-category-name">Bridal Sets</span></h2>
                      <ul class="category-seo-why-list" id="seo-why-list">
                          <li>Expert craftsmanship and premium materials for bridal sets</li>
                          <li>Certified and hallmarked gold and diamond jewellery</li>
                          <li>Trusted jewellery store in Surrey, BC for wedding jewellery</li>
                          <li>Personalized bridal consultation and fitting experience</li>
                          <li>Wide collection for weddings, receptions, and special occasions</li>
                      </ul>
                  </div>
              </div>
          </section>
  
          <section class="section location-section" id="category-store-locations">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Visit Our Store</h2>
                  </div>
                  <div class="location-grid">
                      <article class="location-card">
                          <a href="/surrey/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Surrey-Store1.webp" alt="Bharat Jewellers Surrey">
                          </a>
                          <h3>Surrey</h3>
                          <p>
                              155-8120 128 Street, Surrey, British Columbia V3W 1R1, Canada
                              <br><br>
                              <a href="tel:+16045931111">+1 (604) 593-1111</a>
                              <br>
                              <a href="mailto:surrey@bharatjewellers.ca">surrey@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/surrey/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/calgary/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Calgary.webp" alt="Bharat Jewellers Calgary">
                          </a>
                          <h3>Calgary</h3>
                          <p>
                              Cityscape Landing Plaza, 4310 104 Ave NE #1130, Calgary, AB T3N 1W1, Canada
                              <br><br>
                              <a href="tel:+14035580455">+1 403-558-0455</a>
                              <br>
                              <a href="mailto:calgary@bharatjewellers.ca">calgary@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/calgary/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/edmonton/" class="location-image">
                              <img src="/assets/images/Locations/Jewelry-Stores-Edmonton-1.webp" alt="Bharat Jewellers Edmonton">
                          </a>
                          <h3>Edmonton</h3>
                          <p>
                              9358 34 Ave NW, Edmonton, AB T6E 5X8, Canada
                              <br><br>
                              <a href="tel:+17802626111">+1 780-262-6111</a>
                              <br>
                              <a href="mailto:edmonton@bharatjewellers.ca">edmonton@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/edmonton/">View Store</a>
                      </article>
                  </div>
              </div>
          </section>
  
          <section class="section about-cta">
              <div class="content-wrap">
                  <div class="about-cta-card">
                      <h2>Experience Fine Jewellery in Person</h2>
                      <p>Visit our stores for a personalized experience and explore pieces crafted to last a lifetime.</p>
                      <a class="btn-primary" href="/contact/">Visit Our Store</a>
                  </div>
              </div>
          </section>
  <Fragment slot="afterMain">
    <script is:inline src="/assets/js/category-template.js"></script>
    <script is:inline src="/assets/js/store-locations.js"></script>
  </Fragment>
</BaseLayout>
