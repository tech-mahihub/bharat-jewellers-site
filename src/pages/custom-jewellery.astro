---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Custom Jewellery Collection - Bharat Jewellers";
const pageDescription = "Design bespoke custom jewellery with Bharat Jewellers in Surrey. Work with artisans from concept to final handcrafted piece.";
const canonicalURL = "https://bharatjewellers.ca/custom-jewellery";
const ogImage = "https://bharatjewellers.ca/assets/images/Homepage/Custom-Jewellery-Surrey-BC.webp";
const ogType = "website";
const ogTitle = "Custom Jewellery Collection - Bharat Jewellers";
const keywords = "Custom jewellery, bespoke jewellery design, custom gold jewellery, Bharat Jewellers Surrey";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
>
  <Fragment slot="head">
    <!-- Fonts -->
        <!-- Google tag (gtag.js) -->
        <script>
          window.__BJ_CATEGORY__ = 'custom-jewellery';
        </script>
  </Fragment>
  <section class="section category-hero" id="category-hero">
              <div class="category-hero-overlay"></div>
              <div class="category-hero-inner content-wrap">
                  <span class="category-badge" id="category-badge">Custom Jewellery</span>
                  <h1 id="category-title">Custom Jewellery</h1>
                  <p class="category-intro" id="category-intro">
                      Bring your vision to life with bespoke jewellery designed with our artisans.
                  </p>
              </div>
          </section>
  
          <section class="section category-filter-section">
              <div class="content-wrap">
                  <div class="category-filters" id="category-filters"></div>
              </div>
          </section>
  
          <section class="section category-grid-section">
              <div class="content-wrap">
                  <div class="jewellery-grid" id="jewellery-grid"></div>
              </div>
          </section>
  
          <section class="section category-highlight">
              <div class="category-highlight-inner content-wrap" id="category-highlight">
                  <div class="category-highlight-overlay"></div>
                  <div class="category-highlight-text">
                      <h2 id="category-highlight-title">Create Your Bespoke Jewellery</h2>
                      <p id="category-highlight-text">Transform personal stories into handcrafted jewellery designed exclusively for you.</p>
                      <a class="btn-primary" id="category-highlight-button" href="/contact/">Start Your Design</a>
                  </div>
              </div>
          </section>
  
          <section class="section category-details">
              <div class="content-wrap">
                  <div class="category-details-grid">
                      <div class="category-details-text">
                          <h2 id="category-details-title">Bespoke from Concept to Finish</h2>
                          <p id="category-details-text">Collaborate with our artisans to craft a piece that reflects your vision and celebrates your story.</p>
                      </div>
                      <div class="category-blurb-grid" id="category-blurb-grid"></div>
                  </div>
              </div>
          </section>
  
          <section class="section about-category two-column category-seo" id="seo-about-section" aria-labelledby="seo-about-heading">
              <div class="content-wrap about-category-wrap">
                  <div class="text-content">
                      <h2 id="seo-about-heading" class="category-seo-heading">About <span id="seo-category-name">Custom Jewellery</span></h2>
                      <div class="category-seo-about-content">
                          <p id="seo-about-p1">
                              Bharat Jewellers offers custom jewellery design in Surrey, where handcrafted pieces are created from your vision. Our premium jewellery process combines expert craftsmanship with certified materials and a personalized experience at our jewellery store in Surrey.
                          </p>
                          <p id="seo-about-p2">
                              From initial sketch to final polish, our artisans work with you to create one-of-a-kind rings, necklaces, and sets. We use certified jewellery standards and luxury materials, making us a trusted jeweller in Surrey for bespoke design.
                          </p>
                          <p id="seo-about-p3">
                              Visit our Surrey showroom to start your custom jewellery journey. Whether repurposing heirlooms or creating something new, we deliver handcrafted jewellery tailored to your story and occasion.
                          </p>
                      </div>
                  </div>
                  <div class="image-content">
                      <div class="seo-section-image-wrap">
                          <img id="seo-about-image" src="/assets/images/Homepage/Custom-Jewellery-Surrey-BC.webp" alt="Custom Jewellery – Bharat Jewellers" class="seo-section-image">
                      </div>
                  </div>
              </div>
          </section>
  
          <section class="section why-choose two-column reverse category-seo" id="seo-why-section" aria-labelledby="seo-why-heading">
              <div class="content-wrap why-choose-wrap">
                  <div class="image-content">
                      <div class="seo-section-image-wrap">
                          <img id="seo-why-image" src="/assets/images/Collections/custom-made-gold-diamond-jewellery-bharat-jewellers.webp" alt="Why choose Bharat Jewellers for Custom Jewellery" class="seo-section-image">
                      </div>
                  </div>
                  <div class="text-content">
                      <h2 id="seo-why-heading" class="category-seo-heading">Why Choose <span id="seo-brand-name">Bharat Jewellers</span> for <span id="seo-why-category-name">Custom Jewellery</span></h2>
                      <ul class="category-seo-why-list" id="seo-why-list">
                          <li>Expert craftsmanship and bespoke design from concept to finish</li>
                          <li>Certified gold, diamonds, and gemstones for your custom piece</li>
                          <li>Trusted jewellery store in Surrey, BC for custom design</li>
                          <li>Personalized consultation and one-on-one design experience</li>
                          <li>Handcrafted jewellery for engagements, weddings, and special occasions</li>
                      </ul>
                  </div>
              </div>
          </section>
  
          <section class="section location-section" id="category-store-locations">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Visit Our Store</h2>
                  </div>
                  <div class="location-grid">
                      <article class="location-card">
                          <a href="/surrey/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Surrey-Store1.webp" alt="Bharat Jewellers Surrey">
                          </a>
                          <h3>Surrey</h3>
                          <p>
                              155-8120 128 Street, Surrey, British Columbia V3W 1R1, Canada
                              <br><br>
                              <a href="tel:+16045931111">+1 (604) 593-1111</a>
                              <br>
                              <a href="mailto:surrey@bharatjewellers.ca">surrey@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/surrey/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/calgary/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Calgary.webp" alt="Bharat Jewellers Calgary">
                          </a>
                          <h3>Calgary</h3>
                          <p>
                              Cityscape Landing Plaza, 4310 104 Ave NE #1130, Calgary, AB T3N 1W1, Canada
                              <br><br>
                              <a href="tel:+14035580455">+1 403-558-0455</a>
                              <br>
                              <a href="mailto:calgary@bharatjewellers.ca">calgary@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/calgary/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/edmonton/" class="location-image">
                              <img src="/assets/images/Locations/Jewelry-Stores-Edmonton-1.webp" alt="Bharat Jewellers Edmonton">
                          </a>
                          <h3>Edmonton</h3>
                          <p>
                              9358 34 Ave NW, Edmonton, AB T6E 5X8, Canada
                              <br><br>
                              <a href="tel:+17802626111">+1 780-262-6111</a>
                              <br>
                              <a href="mailto:edmonton@bharatjewellers.ca">edmonton@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/edmonton/">View Store</a>
                      </article>
                  </div>
              </div>
          </section>
  
          <section class="section about-cta">
              <div class="content-wrap">
                  <div class="about-cta-card">
                      <h2>Experience Fine Jewellery in Person</h2>
                      <p>Visit our stores for a personalized experience and explore pieces crafted to last a lifetime.</p>
                      <a class="btn-primary" href="/contact/">Visit Our Store</a>
                  </div>
              </div>
          </section>
  <Fragment slot="afterMain">
    <script is:inline src="/assets/js/category-template.js"></script>
    <script is:inline src="/assets/js/store-locations.js"></script>
  </Fragment>
</BaseLayout>
