const ogTitle = "Bharat Jewellers – Edmonton Store Location";
const keywords = "Bharat Jewellers Edmonton, jewellery store Edmonton, gold jewellery Edmonton, diamond jewellery Edmonton, Indian jewellery Edmonton";
