---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Bharat Jewellers - Category Collection";
const pageDescription = "Explore Bharat Jewellers category collections crafted in gold, diamonds, and bespoke designs.";
const canonicalURL = "https://bharatjewellers.ca/category";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const ogTitle = "Bharat Jewellers - Category Collection";
const keywords = "Bharat Jewellers, gold jewellery collection, diamond jewellery, bridal sets, custom jewellery design, jewellery Surrey Calgary Edmonton";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
>
  <Fragment slot="head">
    <!-- Fonts -->
        <!-- Google tag (gtag.js) -->
  </Fragment>
  <!-- ================= CATEGORY HERO ================= -->
          <section class="section category-hero" id="category-hero">
              <div class="category-hero-overlay"></div>
              <div class="category-hero-inner content-wrap">
                  <span class="category-badge" id="category-badge">Gold Jewellery</span>
                  <h1 id="category-title">Gold Jewellery</h1>
                  <p class="category-intro" id="category-intro">
                      Discover luminous 22K gold jewellery shaped by master artisans.
                  </p>
              </div>
          </section>
  
          <!-- ================= FILTERS ================= -->
          <section class="section category-filter-section">
              <div class="content-wrap">
                  <div class="category-filters" id="category-filters"></div>
              </div>
          </section>
  
          <!-- ================= JEWELLERY GRID ================= -->
          <section class="section category-grid-section">
              <div class="content-wrap">
                  <div class="jewellery-grid" id="jewellery-grid"></div>
              </div>
          </section>
  
          <!-- ================= CATEGORY HIGHLIGHT ================= -->
          <section class="section category-highlight">
              <div class="category-highlight-inner content-wrap" id="category-highlight">
                  <div class="category-highlight-overlay"></div>
                  <div class="category-highlight-text">
                      <h2 id="category-highlight-title">Discover Your Dream Gold Jewellery</h2>
                      <p id="category-highlight-text">Immerse yourself in refined designs crafted with luminous metals, intricate detailing, and enduring brilliance.</p>
                      <a class="btn-primary" id="category-highlight-button" href="/contact/">Contact Us</a>
                  </div>
              </div>
          </section>
  
          <!-- ================= CATEGORY DETAILS ================= -->
          <section class="section category-details">
              <div class="content-wrap">
                  <div class="category-details-grid">
                      <div class="category-details-text">
                          <h2 id="category-details-title">Crafted with Pure 22K Excellence</h2>
                          <p id="category-details-text">From metal selection to final polish, every detail reflects our commitment to lasting beauty and elevated design.</p>
                      </div>
                      <div class="category-blurb-grid" id="category-blurb-grid"></div>
                  </div>
              </div>
          </section>
  
          <!-- ================= SEO: ABOUT CATEGORY (two-column: text left, image right) ================= -->
          <section class="section about-category two-column category-seo" id="seo-about-section" aria-labelledby="seo-about-heading">
              <div class="content-wrap about-category-wrap">
                  <div class="text-content">
                      <h2 id="seo-about-heading" class="category-seo-heading">About <span id="seo-category-name">Gold Jewellery</span></h2>
                      <div class="category-seo-about-content">
                          <p id="seo-about-p1">
                              At Bharat Jewellers, our premium gold jewellery collection in Surrey showcases handcrafted 22K pieces where traditional craftsmanship meets modern design. Each item is certified and hallmarked for purity, offering you a trusted jewellery store experience in Surrey.
                          </p>
                          <p id="seo-about-p2">
                              From everyday wear to wedding and festival occasions, our 22K gold jewellery blends timeless elegance with contemporary silhouettes. Visit our Surrey showroom to explore necklaces, bangles, rings, and chains in a luxury jewellery setting.
                          </p>
                          <p id="seo-about-p3">
                              We combine expert artistry with certified jewellery and transparent service. Whether you seek a single statement piece or a full set, our gold collection delivers premium jewellery you can wear with confidence.
                          </p>
                      </div>
                  </div>
                  <div class="image-content">
                      <div class="seo-section-image-wrap">
                          <img id="seo-about-image" src="/assets/images/Homepage/Gold-Jewellery-Collections.webp" alt="Gold Jewellery – Bharat Jewellers" class="seo-section-image">
                      </div>
                  </div>
              </div>
          </section>
  
          <!-- ================= SEO: WHY CHOOSE (two-column reverse: image left, text right) ================= -->
          <section class="section why-choose two-column reverse category-seo" id="seo-why-section" aria-labelledby="seo-why-heading">
              <div class="content-wrap why-choose-wrap">
                  <div class="image-content">
                      <div class="seo-section-image-wrap">
                          <img id="seo-why-image" src="/assets/images/Necklaces/Necklace_1.webp" alt="Why choose Bharat Jewellers for Gold Jewellery" class="seo-section-image">
                      </div>
                  </div>
                  <div class="text-content">
                      <h2 id="seo-why-heading" class="category-seo-heading">Why Choose <span id="seo-brand-name">Bharat Jewellers</span> for <span id="seo-why-category-name">Gold Jewellery</span></h2>
                      <ul class="category-seo-why-list" id="seo-why-list">
                          <li>Expert craftsmanship and premium 22K gold materials</li>
                          <li>Certified and hallmarked jewellery for guaranteed purity</li>
                          <li>Trusted jewellery store in Surrey, BC</li>
                          <li>Personalized customer experience and aftercare support</li>
                          <li>Wide collection for weddings, festivals, and special occasions</li>
                      </ul>
                  </div>
              </div>
          </section>
  
          <!-- ================= SEO: STORE LOCATIONS (now static for SEO reliability) ================= -->
          <section class="section location-section" id="category-store-locations">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Visit Our Store</h2>
                  </div>
                  <div class="location-grid">
                      <article class="location-card">
                          <a href="/surrey/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Surrey-Store1.webp" alt="Bharat Jewellers Surrey">
                          </a>
                          <h3>Surrey</h3>
                          <p>
                              155-8120 128 Street, Surrey, British Columbia V3W 1R1, Canada
                              <br><br>
                              <a href="tel:+16045931111">+1 (604) 593-1111</a>
                              <br>
                              <a href="mailto:surrey@bharatjewellers.ca">surrey@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/surrey/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/calgary/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Calgary.webp" alt="Bharat Jewellers Calgary">
                          </a>
                          <h3>Calgary</h3>
                          <p>
                              Cityscape Landing Plaza, 4310 104 Ave NE #1130, Calgary, AB T3N 1W1, Canada
                              <br><br>
                              <a href="tel:+14035580455">+1 403-558-0455</a>
                              <br>
                              <a href="mailto:calgary@bharatjewellers.ca">calgary@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/calgary/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/edmonton/" class="location-image">
                              <img src="/assets/images/Locations/Jewelry-Stores-Edmonton-1.webp" alt="Bharat Jewellers Edmonton">
                          </a>
                          <h3>Edmonton</h3>
                          <p>
                              9358 34 Ave NW, Edmonton, AB T6E 5X8, Canada
                              <br><br>
                              <a href="tel:+17802626111">+1 780-262-6111</a>
                              <br>
                              <a href="mailto:edmonton@bharatjewellers.ca">edmonton@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/edmonton/">View Store</a>
                      </article>
                  </div>
              </div>
          </section>
  
          <!-- ================= CTA ================= -->
          <section class="section about-cta">
              <div class="content-wrap">
                  <div class="about-cta-card">
                      <h2>Experience Fine Jewellery in Person</h2>
                      <p>Visit our stores for a personalized experience and explore pieces crafted to last a lifetime.</p>
                      <a class="btn-primary" href="/contact/">Visit Our Store</a>
                  </div>
              </div>
          </section>
  <Fragment slot="afterMain">
    <script is:inline src="/assets/js/category-template.js"></script>
    <script is:inline src="/assets/js/store-locations.js"></script>
  </Fragment>
</BaseLayout>
