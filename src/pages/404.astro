---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Page Not Found - Bharat Jewellers";
const pageDescription = "Bharat Jewellers";
const canonicalURL = "https://bharatjewellers.ca/404/";
const ogImage = "https://bharatjewellers.ca/assets/images/Logo/bharat-jewellers-logo.webp";
const ogType = "website";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
const htmlClass = "dark";
const bodyClass = "bg-background-dark font-sans text-white min-h-screen";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  siteVerification={siteVerification}
  htmlClass={htmlClass}
  bodyClass={bodyClass}
>
  <Fragment slot="head">
    <meta name="robots" content="noindex, nofollow"/>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "primary": "#c9a769",
              "background-dark": "#0a0a0a",
            },
            fontFamily: {
              "display": ["Noto Serif", "serif"],
              "sans": ["Noto Sans", "sans-serif"]
            },
          },
        },
      }
    </script>
  </Fragment>
  <div class="flex-1 flex items-center justify-center px-6 py-24">
  <section class="hero">
  <div class="hero-overlay"></div>
  <div class="hero-inner content-wrap text-center">
  <h1 class="text-6xl font-display font-bold text-primary mb-4">404</h1>
  <p class="hero-sub text-xl mb-6">Page Not Found</p>
  <p class="text-white/70 mb-8 max-w-md mx-auto">The page you're looking for doesn't exist or may have been moved. Explore our gold &amp; diamond jewellery collections or visit one of our stores.</p>
  <a class="btn-primary hero-cta inline-block" href="/">Back to Home</a>
  <div class="mt-6 flex justify-center gap-4 flex-wrap">
  <a href="/collections/" class="text-primary hover:underline">Collections</a>
  <a href="/contact/" class="text-primary hover:underline">Contact</a>
  <a href="/surrey/" class="text-primary hover:underline">Surrey</a>
  <a href="/calgary/" class="text-primary hover:underline">Calgary</a>
  <a href="/edmonton/" class="text-primary hover:underline">Edmonton</a>
  </div>
  </div>
  </section>
  </div>
</BaseLayout>
