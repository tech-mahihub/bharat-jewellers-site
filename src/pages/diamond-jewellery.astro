---
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "Diamond Jewellery Collection - Bharat Jewellers";
const pageDescription = "Explore Bharat Jewellers";
const canonicalURL = "https://bharatjewellers.ca/diamond-jewellery/";
const ogImage = "https://bharatjewellers.ca/assets/images/Homepage/Diamond-Jewellery-Collections.webp";
const ogType = "website";
const ogTitle = "Diamond Jewellery Collection - Bharat Jewellers";
const keywords = "Diamond jewellery collection, diamond rings, diamond earrings, Bharat Jewellers Surrey Calgary Edmonton";
const siteVerification = "CZkkCUYXbJIu7SDSEvl92zX1aUJyZZCN_PBCsLgqssc";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonicalURL={canonicalURL}
  ogImage={ogImage}
  ogType={ogType === "article" ? "article" : "website"}
  ogTitle={ogTitle}
  keywords={keywords}
  siteVerification={siteVerification}
>
  <Fragment slot="head">
    <!-- Fonts -->
        <!-- Google tag (gtag.js) -->
        <script>
          window.__BJ_CATEGORY__ = 'diamond-jewellery';
        </script>
  </Fragment>
  <section class="section category-hero" id="category-hero">
              <div class="category-hero-overlay"></div>
              <div class="category-hero-inner content-wrap">
                  <span class="category-badge" id="category-badge">Diamond Jewellery</span>
                  <h1 id="category-title">Diamond Jewellery</h1>
                  <p class="category-intro" id="category-intro">
                      Experience refined brilliance with diamonds selected for clarity and fire.
                  </p>
              </div>
          </section>
  
          <section class="section category-filter-section">
              <div class="content-wrap">
                  <div class="category-filters" id="category-filters"></div>
              </div>
          </section>
  
          <section class="section category-grid-section">
              <div class="content-wrap">
                  <div class="jewellery-grid" id="jewellery-grid"></div>
              </div>
          </section>
  
          <section class="section category-highlight">
              <div class="category-highlight-inner content-wrap" id="category-highlight">
                  <div class="category-highlight-overlay"></div>
                  <div class="category-highlight-text">
                      <h2 id="category-highlight-title">Discover Your Signature Diamond Jewellery</h2>
                      <p id="category-highlight-text">Illuminate every moment with diamonds selected for clarity, brilliance, and refined elegance.</p>
                      <a class="btn-primary" id="category-highlight-button" href="/contact/">Visit Our Store</a>
                  </div>
              </div>
          </section>
  
          <section class="section category-details">
              <div class="content-wrap">
                  <div class="category-details-grid">
                      <div class="category-details-text">
                          <h2 id="category-details-title">Brilliance in Every Detail</h2>
                          <p id="category-details-text">Our diamond collections pair exceptional stones with meticulous craftsmanship for an elevated finish.</p>
                      </div>
                      <div class="category-blurb-grid" id="category-blurb-grid"></div>
                  </div>
              </div>
          </section>
  
          <section class="section about-category two-column category-seo" id="seo-about-section" aria-labelledby="seo-about-heading">
              <div class="content-wrap about-category-wrap">
                  <div class="text-content">
                      <h2 id="seo-about-heading" class="category-seo-heading">About <span id="seo-category-name">Diamond Jewellery</span></h2>
                      <div class="category-seo-about-content">
                          <p id="seo-about-p1">
                              Bharat Jewellers brings you premium diamond jewellery in Surrey, featuring handcrafted pieces set with certified stones. Our collection balances luxury jewellery design with everyday wearability, from engagement rings to earrings and pendants.
                          </p>
                          <p id="seo-about-p2">
                              Each diamond is chosen for clarity and cut, then set by skilled artisans. As a trusted jeweller in Surrey, we offer certified jewellery with transparent pricing and a personalized in-store experience.
                          </p>
                          <p id="seo-about-p3">
                              Visit our Surrey store to explore diamond rings, bracelets, and sets. Whether for an engagement, anniversary, or a special occasion, our diamond jewellery collection delivers refined brilliance you can rely on.
                          </p>
                      </div>
                  </div>
                  <div class="image-content">
                      <div class="seo-section-image-wrap">
                          <img id="seo-about-image" src="/assets/images/Homepage/Diamond-Jewellery-Collections.webp" alt="Diamond Jewellery – Bharat Jewellers" class="seo-section-image">
                      </div>
                  </div>
              </div>
          </section>
  
          <section class="section why-choose two-column reverse category-seo" id="seo-why-section" aria-labelledby="seo-why-heading">
              <div class="content-wrap why-choose-wrap">
                  <div class="image-content">
                      <div class="seo-section-image-wrap">
                          <img id="seo-why-image" src="/assets/images/Earrings/Earrings_1.webp" alt="Why choose Bharat Jewellers for Diamond Jewellery" class="seo-section-image">
                      </div>
                  </div>
                  <div class="text-content">
                      <h2 id="seo-why-heading" class="category-seo-heading">Why Choose <span id="seo-brand-name">Bharat Jewellers</span> for <span id="seo-why-category-name">Diamond Jewellery</span></h2>
                      <ul class="category-seo-why-list" id="seo-why-list">
                          <li>Expert craftsmanship and premium diamond selection</li>
                          <li>Certified and hallmarked jewellery with authenticated stones</li>
                          <li>Trusted jewellery store in Surrey, BC</li>
                          <li>Personalized guidance for engagement and special occasions</li>
                          <li>Wide collection of premium diamond jewellery for every moment</li>
                      </ul>
                  </div>
              </div>
          </section>
  
          <section class="section location-section" id="category-store-locations">
              <div class="content-wrap">
                  <div class="section-title">
                      <h2>Visit Our Store</h2>
                  </div>
                  <div class="location-grid">
                      <article class="location-card">
                          <a href="/surrey/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Surrey-Store1.webp" alt="Bharat Jewellers Surrey">
                          </a>
                          <h3>Surrey</h3>
                          <p>
                              155-8120 128 Street, Surrey, British Columbia V3W 1R1, Canada
                              <br><br>
                              <a href="tel:+16045931111">+1 (604) 593-1111</a>
                              <br>
                              <a href="mailto:surrey@bharatjewellers.ca">surrey@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/surrey/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/calgary/" class="location-image">
                              <img src="/assets/images/Locations/Bharat-Jewellers-Calgary.webp" alt="Bharat Jewellers Calgary">
                          </a>
                          <h3>Calgary</h3>
                          <p>
                              Cityscape Landing Plaza, 4310 104 Ave NE #1130, Calgary, AB T3N 1W1, Canada
                              <br><br>
                              <a href="tel:+14035580455">+1 403-558-0455</a>
                              <br>
                              <a href="mailto:calgary@bharatjewellers.ca">calgary@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/calgary/">View Store</a>
                      </article>
                      <article class="location-card">
                          <a href="/edmonton/" class="location-image">
                              <img src="/assets/images/Locations/Jewelry-Stores-Edmonton-1.webp" alt="Bharat Jewellers Edmonton">
                          </a>
                          <h3>Edmonton</h3>
                          <p>
                              9358 34 Ave NW, Edmonton, AB T6E 5X8, Canada
                              <br><br>
                              <a href="tel:+17802626111">+1 780-262-6111</a>
                              <br>
                              <a href="mailto:edmonton@bharatjewellers.ca">edmonton@bharatjewellers.ca</a>
                          </p>
                          <a class="location-link" href="/edmonton/">View Store</a>
                      </article>
                  </div>
              </div>
          </section>
  
          <section class="section about-cta">
              <div class="content-wrap">
                  <div class="about-cta-card">
                      <h2>Experience Fine Jewellery in Person</h2>
                      <p>Visit our stores for a personalized experience and explore pieces crafted to last a lifetime.</p>
                      <a class="btn-primary" href="/contact/">Visit Our Store</a>
                  </div>
              </div>
          </section>
  <Fragment slot="afterMain">
    <script is:inline src="/assets/js/category-template.js"></script>
    <script is:inline src="/assets/js/store-locations.js"></script>
  </Fragment>
</BaseLayout>
